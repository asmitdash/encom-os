# Force LF on every file that runs inside the Linux ISO build container.
# Without this, OneDrive/Windows checkouts produce CRLF and break archiso.
*.sh           text eol=lf
profiledef.sh  text eol=lf
packages.*     text eol=lf
pacman.conf    text eol=lf
*.conf         text eol=lf
iso/airootfs/** text eol=lf

# Rust + TS / TOML / JSON / YAML are tool-friendly to LF too.
*.rs   text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
